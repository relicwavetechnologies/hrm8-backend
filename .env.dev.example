DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Airwallex sandbox (api-demo.airwallex.com = fake money)
BILLING_PROVIDER_MODE=live
AIRWALLEX_CLIENT_ID=your_client_id
AIRWALLEX_API_KEY=your_api_key
AIRWALLEX_API_BASE_URL=https://api-demo.airwallex.com
AIRWALLEX_WEBHOOK_SECRET=your_webhook_secret

# Fall back to mock when live Airwallex API fails (default: true). Set false in prod to fail hard.
# AIRWALLEX_FALLBACK_TO_MOCK_ON_ERROR=true

# For local dev with tunnel (e.g. cloudflared), set so checkout redirect URL is reachable:
# BACKEND_URL=https://your-tunnel.trycloudflare.com
# ATS_FRONTEND_URL=https://your-tunnel.trycloudflare.com
